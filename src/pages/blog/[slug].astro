---
import Layout from "../../layouts/Layout.astro";
import Newsletter from "../../components/Newsletter";
import type { MetaProps } from "../../components/MetaTags.astro";
import { Image } from "astro:assets";
import BlogContent from "../../components/BlogContent.astro";
import { fetchPageBySlug, fetchPages } from "../../services/notion";

export const prerender = true;

interface Props {
  post: any;
  meta: MetaProps;
}

export async function getStaticPaths() {
  const posts = (await fetchPages()).results;
  const postData = Promise.all(
    posts.map(async (item) => {
      const postObject = await fetchPageBySlug(item.properties.Slug.url);
      return {
        params: {
          slug: postObject?.properties.Slug.url,
        },
        props: {
          post: {
            id: postObject?.id as string,
            title: postObject?.properties.Title.title[0].plain_text,
            date: item.properties["Published Date"].date.start,
            slug: postObject?.properties.Slug.url,
          },
          meta: {
            title: postObject?.properties.Title.title[0].plain_text,
            description:
              postObject?.properties.Excerpt.rich_text[0] == undefined
                ? ""
                : postObject?.properties.Excerpt.rich_text[0].plain_text,
            image: postObject?.cover
              ? postObject?.cover.external
                ? postObject?.cover.external.url
                : postObject?.cover.file.url
              : null,
            tags:
              postObject?.properties.Tags.rich_text[0] == undefined
                ? ""
                : postObject.properties.Excerpt.rich_text[0].plain_text,
            url:
              "https://prannaykedia.com/blog/" +
              postObject?.properties.Slug.url,
          },
        },
      };
    })
  );

  return postData;
}
const { post, meta } = Astro.props;
---

<Layout title={post.title} metaData={meta}>
  <section
    id="blog-header"
    class="flex-col flex md:flex-row items-center lg:px-24 md:px-24 px-6 mt-12 gap-12 justify-around">
    <div
      class="order-2 md:order-1 md:max-w-2xl flex flex-col gap-3 text-center md:text-start md:gap-6">
      <h1 class="text-2xl md:text-4xl font-bold">
        {post.title}
      </h1>
      <p class="text-gray-500 font-light text-xs md:text-sm">
        {
          new Date(post.date ?? "1.1.2023").toLocaleDateString(undefined, {
            year: "numeric",
            month: "long",
            day: "2-digit",
          })
        }
      </p>
    </div>
    <Image
      width={2400}
      height={1000}
      transition:name={post.slug}
      src={meta.image || ""}
      class="md:w-1/2 aspect-video md:order-2 rounded-xl"
      alt={post.title || ""}
    />
  </section>

  <section id="blog-content">
    <BlogContent id={post.id} />
  </section>

  <Newsletter client:visible />
</Layout>
